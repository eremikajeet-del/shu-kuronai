generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  username      String   @unique
  password      String
  name          String?
  role          String   @default("STUDENT")
  status        String   @default("PENDING")
  avatar        String?
  xp            Int      @default(0)
  level         Int      @default(1)
  streak        Int      @default(0)
  longestStreak Int      @default(0)
  lastStudyDate String?
  autoApprove   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  topics       Topic[]
  studyLogs    StudyLog[]
  flashcards   Flashcard[]
  mockTests    MockTest[]
  mistakes     Mistake[]
  quizResults  QuizResult[]
  goals        Goal[]
  notes        Note[]
  files        File[]
  achievements UserAchievement[]
  revisions    RevisionSchedule[]
}

model Topic {
  id          String   @id @default(cuid())
  userId      String
  subject     String
  topicName   String
  description String?
  status      String   @default("ACTIVE")
  mastery     Int      @default(0)
  examDate    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  revisions RevisionSchedule[]
  flashcards Flashcard[]
  quizResults QuizResult[]

  @@index([userId])
  @@index([subject])
}

model RevisionSchedule {
  id             String   @id @default(cuid())
  userId         String
  topicId        String
  revisionDate   DateTime
  revisionNumber Int
  status         String   @default("PENDING")
  difficulty     String?
  completedAt    DateTime?
  nextRevision   DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([revisionDate])
  @@index([status])
}

model StudyLog {
  id          String   @id @default(cuid())
  userId      String
  subject     String
  topic       String
  duration    Int
  notes       String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
}

model Flashcard {
  id         String   @id @default(cuid())
  userId     String
  topicId    String?
  subject    String
  front      String
  back       String
  isLearned  Boolean  @default(false)
  repeatCount Int     @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic Topic? @relation(fields: [topicId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([subject])
}

model MockTest {
  id          String   @id @default(cuid())
  userId      String
  subject     String
  topic       String
  totalMarks  Int
  obtainedMarks Int
  date        DateTime @default(now())
  analysis    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Mistake {
  id          String   @id @default(cuid())
  userId      String
  subject     String
  topic       String
  description String
  mistakeType String
  correction  String?
  isResolved  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([mistakeType])
}

model QuizResult {
  id           String   @id @default(cuid())
  userId       String
  topicId      String?
  subject      String
  totalQuestions Int
  correctAnswers Int
  score        Float
  timeTaken    Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic Topic? @relation(fields: [topicId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([subject])
}

model Goal {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  type        String
  target      Int
  current     Int      @default(0)
  deadline    DateTime?
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
}

model Note {
  id          String   @id @default(cuid())
  userId      String
  subject     String
  title       String
  content     String
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([subject])
}

model File {
  id          String   @id @default(cuid())
  userId      String
  name        String
  url         String
  type        String
  subject     String?
  size        Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Formula {
  id          String   @id @default(cuid())
  subject     String
  title       String
  content     String
  category    String?
  isLearned   Boolean  @default(false)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([subject])
  @@index([category])
}

model QuizQuestion {
  id          String   @id @default(cuid())
  subject     String
  topic       String
  question    String
  optionA     String
  optionB     String
  optionC     String
  optionD     String
  correctAnswer String
  explanation String?
  difficulty  String   @default("MEDIUM")
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([subject])
  @@index([topic])
}

model Achievement {
  id          String   @id @default(cuid())
  name        String
  description String
  icon        String
  xpReward    Int
  condition   String
  createdAt   DateTime @default(now())

  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  earnedAt      DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
}
